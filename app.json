{
  "expo": {
    "name": "lost-person-alert",
    "slug": "lost-person-alert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "lostpersonalert",
      "com.googleusercontent.apps.389857812215-vdig4mm0b4luri0biam5f5bi5pb0o7ls"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.lostpersonalert",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "NSLocationWhenInUseUsageDescription": "This app needs your location to show missing persons in your area and help track them.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs background location to continuously track missing persons and alert you when you are near a case.",
        "NSLocationAlwaysUsageDescription": "This app needs background location to continuously track missing persons and alert you when you are near a case."
      }
    },
    "android": {
      "package": "com.yourname.lostpersonalert",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "DUMMY_NOT_USED"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "lostpersonalert",
              "host": "auth"
            }
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "com.googleusercontent.apps.389857812215-vdig4mm0b4luri0biam5f5bi5pb0o7ls"
            }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Lost Person Alert to use your location to track missing persons in your area and alert you when you are near a case.",
          "locationAlwaysPermission": "Allow Lost Person Alert to use your location in the background to continuously monitor for missing persons near you.",
          "locationWhenInUsePermission": "Allow Lost Person Alert to use your location to show missing persons in your area on the map."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7d177a10-9843-444b-ba07-c806bb99993e"
      }
    }
  }
}
